<%- partial('partial/header') %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="hero-content">
    <h1 class="hero-title"><%= config.author || 'sido' %></h1>
    <p class="hero-subtitle"><%= config.subtitle || 'Personal Website' %></p>
    <p class="hero-description"><%= page.description || config.description || '' %></p>
  </div>
</section>

<!-- Main Layout -->
<div class="home-layout">
  <!-- Profile Sidebar -->
  <aside class="profile-sidebar">
    <div class="profile-card">
      <div class="profile-avatar">
        <div class="avatar-placeholder">
          <span class="initials"><%= config.author.charAt(0) %></span>
        </div>
      </div>
      <h2 class="profile-name"><%= config.author || 'sido' %></h2>
      <p class="profile-role"><%= (theme.profile && theme.profile.role) || 'Professional Role' %></p>
      
      <!-- Social Links -->
      <div class="profile-social">
        <ul>
          <% if ((theme.profile && theme.profile.social_links && theme.profile.social_links.length)) {
            theme.profile.social_links.forEach(function(link) {
          %>
            <li><a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" title="<%= link.name %>"><i class="<%= link.icon %>" aria-hidden="true"></i></a></li>
          <% });
          } else {
          %>
            <!-- Default Social Links -->
            <li><a href="#" target="_blank" rel="noopener noreferrer" title="GitHub"><i class="fa fa-github" aria-hidden="true"></i></a></li>
            <li><a href="#" target="_blank" rel="noopener noreferrer" title="LinkedIn"><i class="fa fa-linkedin" aria-hidden="true"></i></a></li>
            <li><a href="#" target="_blank" rel="noopener noreferrer" title="Twitter"><i class="fa fa-twitter" aria-hidden="true"></i></a></li>
          <% } %>
        </ul>
      </div>

      <!-- Academic Links -->
      <div class="profile-academic">
        <ul>
          <% if ((theme.profile && theme.profile.academic_links && theme.profile.academic_links.length)) {
            theme.profile.academic_links.forEach(function(link) {
          %>
            <li><a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" title="<%= link.name %>"><i class="<%= link.icon %>" aria-hidden="true"></i> <%= link.name %></a></li>
          <% });
          } else {
          %>
            <!-- Default Academic Links -->
            <li><a href="#" target="_blank" rel="noopener noreferrer" title="Google Scholar"><i class="fa fa-graduation-cap" aria-hidden="true"></i> Google Scholar</a></li>
            <li><a href="#" target="_blank" rel="noopener noreferrer" title="ORCID"><i class="fa fa-id-card" aria-hidden="true"></i> ORCID</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </aside>

  <!-- Content Area -->
  <article class="content-area">
    <h1 class="page-title"><%= page.title || 'sido\'s Personal Website' %></h1>
    <div class="page-content">
      <!-- 关于我 -->
      <section id="about">
        <h2>About Me</h2>
        <p>欢迎来到我的个人网站！我是一名[Your Profession/Field]，拥有[X]年的专业经验。我专注于[Your Expertise Areas]，并对[Your Interests]充满热情。</p>
      </section>

      <!-- 专业背景 -->
      <section id="professional">
        <h2>Professional Background</h2>
        <p>我目前在[Current Company/Institution]担任[Your Position]，负责[Your Responsibilities]。在此之前，我曾在[Previous Company/Institution]工作，积累了宝贵的经验和技能。</p>
      </section>

      <!-- 教育背景 -->
      <section id="education">
        <h2>Education</h2>
        <p>我拥有[Your Degree]学位，毕业于[Your University]，专业是[Your Major]。在校期间，我专注于[Your Focus Areas]的学习和研究。</p>
      </section>

      <!-- 最新动态 -->
      <section id="news">
        <h2>News</h2>
        <ul>
          <li><strong>[Date]</strong> [Latest News/Update]</li>
          <li><strong>[Date]</strong> [Previous News/Update]</li>
        </ul>
      </section>

      <!-- 精选出版物 -->
      <section id="publications">
        <h2>Selected Publications</h2>
        <ul>
          <li>[Your Publication 1] - <em>[Journal/Conference]</em>, [Year]</li>
          <li>[Your Publication 2] - <em>[Journal/Conference]</em>, [Year]</li>
        </ul>
      </section>

      <!-- 项目 -->
      <section id="projects">
        <h2>Projects</h2>
        <ul>
          <li><strong>[Project Name 1]</strong> - [Brief Description]</li>
          <li><strong>[Project Name 2]</strong> - [Brief Description]</li>
        </ul>
      </section>

      <!-- 联系方式 -->
      <section id="contact">
        <h2>Contact</h2>
        <p>您可以通过以下方式联系我：</p>
        <ul>
          <li>电子邮件：[Your Email Address]</li>
          <li>社交媒体：[Your Social Media Links]</li>
        </ul>
      </section>
    </div>
  </article>
</div>

<%- partial('partial/footer') %>